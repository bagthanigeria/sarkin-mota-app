# Server Configuration
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000
API_VERSION=v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sarkin_mota_dev
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key
REFRESH_TOKEN_EXPIRE=30d

# Payment Gateways
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=paystack_webhook_secret

FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_your_flutterwave_key
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST_your_public_key
FLUTTERWAVE_WEBHOOK_SECRET=flutterwave_webhook_secret

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=sarkin-mota-uploads-dev
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET_URL=https://sarkin-mota-uploads-dev.s3.amazonaws.com

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=noreply@sarkinmota.com
MAIL_PASSWORD=your_email_password
MAIL_FROM=SARKIN MOTA <noreply@sarkinmota.com>

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_PROJECT_ID=sarkin-mota
FIREBASE_DATABASE_URL=https://sarkin-mota.firebaseio.com

# Admin Configuration
ADMIN_EMAIL=admin@sarkinmota.com
ADMIN_PASSWORD=change_this_password

# App Configuration
APP_NAME=SARKIN MOTA
APP_VERSION=1.0.0
LOG_LEVEL=debug

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:8000
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,video/mp4,video/quicktime

# Session Configuration
SESSION_SECRET=your_session_secret_key
SESSION_MAX_AGE=86400000
